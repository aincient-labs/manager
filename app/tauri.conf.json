{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIncient Manager",
  "version": "0.1.0",
  "identifier": "io.aincient.manager",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AIncient Manager",
        "width": 480,
        "height": 680,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
