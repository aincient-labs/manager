{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atelier Manager",
  "version": "0.2.5",
  "identifier": "io.aincient.manager",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Atelier Manager",
        "width": 860,
        "height": 640,
        "minWidth": 640,
        "minHeight": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
